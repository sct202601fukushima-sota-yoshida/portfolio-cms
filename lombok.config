# Lombok 設定
# https://projectlombok.org/features/configuration

# Lombok が生成したメソッドに @lombok.Generated アノテーションを付与する。
# JaCoCo はこのアノテーションを自動検出してカバレッジ計測から除外するため、
# Getter/Setter/equals/hashCode/toString/RequiredArgsConstructor などの
# trivial な生成コードがカバレッジ %  を膨らませなくなる。
lombok.addLombokGeneratedAnnotation = true

# 設定ファイルがプロジェクトルートにあることを宣言（上位の lombok.config を継承させない）
config.stopBubbling = true
